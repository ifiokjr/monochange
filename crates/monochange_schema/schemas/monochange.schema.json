{
	"$defs": {
		"BumpSeverity": {
			"enum": [
				"none",
				"patch",
				"minor",
				"major"
			],
			"type": "string"
		},
		"ChangelogDefinition": {
			"oneOf": [
				{
					"enum": [
						"Disabled",
						"PackageDefault"
					],
					"type": "string"
				},
				{
					"additionalProperties": false,
					"properties": {
						"PathPattern": {
							"type": "string"
						}
					},
					"required": [
						"PathPattern"
					],
					"type": "object"
				}
			]
		},
		"ChangelogFormat": {
			"enum": [
				"monochange",
				"keep_a_changelog"
			],
			"type": "string"
		},
		"ChangelogSectionDef": {
			"properties": {
				"description": {
					"default": null,
					"description": "Description of when this section should appear.",
					"type": [
						"string",
						"null"
					]
				},
				"heading": {
					"description": "Display heading for the section in rendered changelogs.",
					"type": "string"
				},
				"priority": {
					"default": 100,
					"description": "Ordering priority for changelog rendering. Lower values appear first.",
					"format": "int8",
					"maximum": 127,
					"minimum": -128,
					"type": "integer"
				}
			},
			"required": [
				"heading"
			],
			"type": "object"
		},
		"ChangelogSectionThresholds": {
			"properties": {
				"collapse": {
					"default": 127,
					"description": "Collapse sections whose priority is greater than or equal to this value.",
					"format": "int8",
					"maximum": 127,
					"minimum": -128,
					"type": "integer"
				},
				"ignored": {
					"default": 127,
					"description": "Omit sections whose priority is strictly greater than this value.",
					"format": "int8",
					"maximum": 127,
					"minimum": -128,
					"type": "integer"
				}
			},
			"type": "object"
		},
		"ChangelogSettings": {
			"description": "Top-level `[changelog]` configuration combining templates, sections, and types.",
			"properties": {
				"section_thresholds": {
					"$ref": "#/$defs/ChangelogSectionThresholds",
					"default": {
						"collapse": 127,
						"ignored": 127
					}
				},
				"sections": {
					"additionalProperties": {
						"$ref": "#/$defs/ChangelogSectionDef"
					},
					"default": {},
					"type": "object"
				},
				"templates": {
					"default": [],
					"items": {
						"type": "string"
					},
					"type": "array"
				},
				"types": {
					"additionalProperties": {
						"$ref": "#/$defs/ChangelogType"
					},
					"default": {},
					"type": "object"
				}
			},
			"type": "object"
		},
		"ChangelogTarget": {
			"properties": {
				"format": {
					"$ref": "#/$defs/ChangelogFormat",
					"default": "monochange"
				},
				"initial_header": {
					"type": [
						"string",
						"null"
					]
				},
				"path": {
					"type": "string"
				}
			},
			"required": [
				"path"
			],
			"type": "object"
		},
		"ChangelogType": {
			"properties": {
				"bump": {
					"$ref": "#/$defs/BumpSeverity",
					"default": "none",
					"description": "Semver bump severity implied by this changeset type."
				},
				"description": {
					"default": null,
					"description": "Human-readable description of when to use this type.",
					"type": [
						"string",
						"null"
					]
				},
				"section": {
					"description": "Section key this type routes to (references a `[changelog.sections]` key).",
					"type": "string"
				}
			},
			"required": [
				"section"
			],
			"type": "object"
		},
		"ChangesetAffectedSettings": {
			"properties": {
				"changed_paths": {
					"default": [],
					"items": {
						"type": "string"
					},
					"type": "array"
				},
				"comment_on_failure": {
					"default": true,
					"type": "boolean"
				},
				"enabled": {
					"default": true,
					"type": "boolean"
				},
				"ignored_paths": {
					"default": [],
					"items": {
						"type": "string"
					},
					"type": "array"
				},
				"required": {
					"default": true,
					"type": "boolean"
				},
				"skip_labels": {
					"default": [],
					"items": {
						"type": "string"
					},
					"type": "array"
				}
			},
			"type": "object"
		},
		"ChangesetSettings": {
			"properties": {
				"affected": {
					"$ref": "#/$defs/ChangesetAffectedSettings",
					"default": {
						"changed_paths": [],
						"comment_on_failure": true,
						"enabled": true,
						"ignored_paths": [],
						"required": true,
						"skip_labels": []
					}
				}
			},
			"type": "object"
		},
		"CliCommandDefinition": {
			"properties": {
				"help_text": {
					"default": null,
					"type": [
						"string",
						"null"
					]
				},
				"inputs": {
					"default": [],
					"items": {
						"$ref": "#/$defs/CliInputDefinition"
					},
					"type": "array"
				},
				"name": {
					"type": "string"
				},
				"steps": {
					"default": [],
					"items": {
						"$ref": "#/$defs/CliStepDefinition"
					},
					"type": "array"
				}
			},
			"required": [
				"name"
			],
			"type": "object"
		},
		"CliInputDefinition": {
			"properties": {
				"choices": {
					"default": [],
					"items": {
						"type": "string"
					},
					"type": "array"
				},
				"default": {
					"default": null,
					"type": [
						"string",
						"null"
					]
				},
				"help_text": {
					"default": null,
					"type": [
						"string",
						"null"
					]
				},
				"name": {
					"type": "string"
				},
				"required": {
					"default": false,
					"type": "boolean"
				},
				"short": {
					"default": null,
					"maxLength": 1,
					"minLength": 1,
					"type": [
						"string",
						"null"
					]
				},
				"type": {
					"$ref": "#/$defs/CliInputKind"
				}
			},
			"required": [
				"name",
				"type"
			],
			"type": "object"
		},
		"CliInputKind": {
			"enum": [
				"string",
				"string_list",
				"path",
				"choice",
				"boolean"
			],
			"type": "string"
		},
		"CliStepDefinition": {
			"description": "Built-in execution units for `[[cli.<command>.steps]]`.\n\n`monochange` runs steps in order and lets later steps consume state created by\nearlier ones. Use standalone steps such as `Validate`, `Discover`,\n`AffectedPackages`, `DiagnoseChangesets`, and `RetargetRelease` when you want\ninspection or repair. Use `PrepareRelease` when later steps need structured\nrelease state.\n\nSee the CLI step reference in the book for full workflow guidance.",
			"oneOf": [
				{
					"additionalProperties": false,
					"description": "Expose the resolved `monochange` configuration and workspace root.",
					"properties": {
						"inputs": {
							"additionalProperties": {
								"$ref": "#/$defs/CliStepInputValue"
							},
							"default": {},
							"type": "object"
						},
						"name": {
							"default": null,
							"type": [
								"string",
								"null"
							]
						},
						"type": {
							"const": "Config",
							"type": "string"
						},
						"when": {
							"default": null,
							"type": [
								"string",
								"null"
							]
						}
					},
					"required": [
						"type"
					],
					"type": "object"
				},
				{
					"additionalProperties": false,
					"description": "Validate `monochange` configuration and changesets, and run lint rules\non package manifests.",
					"properties": {
						"inputs": {
							"additionalProperties": {
								"$ref": "#/$defs/CliStepInputValue"
							},
							"default": {},
							"type": "object"
						},
						"name": {
							"default": null,
							"type": [
								"string",
								"null"
							]
						},
						"type": {
							"const": "Validate",
							"type": "string"
						},
						"when": {
							"default": null,
							"type": [
								"string",
								"null"
							]
						}
					},
					"required": [
						"type"
					],
					"type": "object"
				},
				{
					"additionalProperties": false,
					"description": "Discover packages across supported ecosystems and render the result.",
					"properties": {
						"inputs": {
							"additionalProperties": {
								"$ref": "#/$defs/CliStepInputValue"
							},
							"default": {},
							"type": "object"
