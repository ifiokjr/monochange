{
	"name": "@monochange/root",
	"private": true,
	"description": "Monorepo root for monochange npm packages",
	"license": "Unlicense",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/monochange/monochange.git"
	},
	"scripts": {
		"check": "tsgo -config tsconfig.json",
		"fmt": "oxfmt --write .",
		"fmt:check": "oxfmt --check .",
		"lint": "oxlint --type-aware .",
		"lint:syntax": "oxlint .",
		"build": "tsdown"
	},
	"devDependencies": {
		"@rslint/tsgo": "^0.5.0",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"oxlint-tsgolint": "^0.22.0",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=9"
	}
}
