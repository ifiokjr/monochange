{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": false,
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"skipLibCheck": true,
		"target": "ES2024"
	},
	"exclude": ["dist", "fixtures", "node_modules", "target"],
	"include": ["npm/tests/**/*.mjs", "scripts/**/*.mjs"]
}
