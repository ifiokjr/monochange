#!/bin/sh
set -eu
version=$(awk -F '"' '/"version"/ { print $4; exit }' package.json)
cat > package-lock.json <<EOF
{
  "name": "app",
  "version": "$version",
  "lockfileVersion": 3,
  "packages": {
    "": { "name": "app", "version": "$version" }
  },
  "dependencies": { "app": { "version": "$version" } }
}
EOF
