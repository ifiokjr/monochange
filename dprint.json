{
	"incremental": true,
	"indentWidth": 2,
	"useTabs": true,
	"exec": {
		"commands": [
			{
				"command": "rustfmt --edition 2024",
				"exts": ["rs"]
			},
			{
				"command": "nixfmt",
				"exts": ["nix"]
			},
			{
				"command": "shfmt --filename {{file_path}} -i 0",
				"exts": ["sh", "bash"]
			}
		]
	},
	"oxc": {
		"indentStyle": "tab",
		"lineWidth": 100,
		"indentWidth": 2
	},
	"json": {
		"deno": true,
		"useTabs": true
	},
	"toml": {
		"useTabs": true,
		"indentWidth": 2,
		"cargo.applyConventions": true
	},
	"markdown": {
		"deno": true,
		"textWrap": "never"
	},
	"excludes": [
		"**/dist",
		"docs/book",
		".devenv/**",
		".tmp-node/**",
		"**/fixtures",
		"**/fixtures/**",
		"fixtures/**",
		"**/snapshots",
		"**/target",
		"**/node_modules",
		"**/pnpm-lock.yaml",
		".bin/",
		"**/*.toml.template"
	],
	"plugins": [
		"https://plugins.dprint.dev/oxc-0.20.0.wasm",
		"https://plugins.dprint.dev/json-0.21.3.wasm",
		"https://plugins.dprint.dev/markdown-0.21.1.wasm",
		"https://plugins.dprint.dev/exec-0.6.2.json@df98f54ffd3092b8a841aedd6d098a2651f16d0a796a40535774f1a8b4b9d463",
		"https://plugins.dprint.dev/toml-0.7.0.wasm",
		"https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm"
	]
}
